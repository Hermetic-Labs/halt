# ==============================================================================
# HALT .gitignore — Git vs Cloudflare Separation
# ==============================================================================
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  GIT (this repo — source only)  │  CLOUDFLARE R2                            │
# │  → github.com/Hermetic-Labs     │                                           │
# │                                 │  BUILDS (end users):                      │
# │  api/          backend source   │    HALT-v1.0.0-Windows.zip                │
# │  electron/     shell source     │    HALT-latest-Windows.zip                │
# │  viewer/       frontend dist    │                                           │
# │  triage/       medical data     │  DEV ASSETS (after git clone):            │
# │  dev/          build + setup    │    models.zip → extracts to models/       │
# │  assets/       logo, branding   │    runtime-windows.zip → runtime/         │
# │  start.py, launchers, docs      │                                           │
# │                                 │  Setup: python dev/setup.py               │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Large assets (downloaded from R2 via dev/setup.py, NOT in git) ────────────
# These are dev-only — the built app on R2 already bundles everything.
models/
runtime/

# ── Built distributions (Cloudflare R2, not Git) ─────────────────────────────
builds/
output/
HALT-v1.0.01/
HALT-*.zip
*.zip

# ── Electron build artifacts (produced by electron-builder) ──────────────────
dev/electron-launcher/dist/
dev/electron-launcher/app-stage/

# ── Runtime user data + secrets (never committed) ────────────────────────────
patients/
*.key
.env

# ── Raw source data (generated triage data is in triage/conditions/) ──────────
triage/_source/icd10cm-2025/
triage/_source/icd10cm-2025.zip

# ── Test / temp directories ──────────────────────────────────────────────────
__fresh_test__/

# ── Node modules (reinstallable) ─────────────────────────────────────────────
node_modules/

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
.ruff_cache/
*.pyc
*.pyo

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
._*
desktop.ini
Thumbs.db

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
.gemini/
.claude/

# ── Abandoned scripts (not part of the build) ────────────────────────────────
diag.py

# ── GitHub Pages site (separate repo, no bleed) ──────────────────────────────
site/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
halt-log.txt

# Temporary/personal docs
*.pdf

# Apple signing credentials
*.p12
*.cer
dev/macos/*.pem

# Apple distribution signing (never commit)
*.key
*.certSigningRequest
*.cer
*.p12
