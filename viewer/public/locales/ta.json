  "bp.phase_a": "காற்று வழி",
  "bp.phase_r": "சுவாசம்",
  "bp.phase_c": "சுழற்சி",
  "bp.phase_h": "ஹைபோதர்மி தடுப்பு",
  "bp.m_tourniquet": "சுழற்சியைப் பயன்படுத்தவும் - உயரமாகவும் இறுக்கமாகவும், காயத்திற்கு அருகிலுள்ள 2-3 இல். சுழற்சியில் நேரத்தை எழுதுங்கள்.",
  "bp.m_pack_wound": "பேக் காயம்ஃ ஹீமோஸ்டாடிக் காஸ் (கம்பாட் காஸ்), நேரடி அழுத்தம் 3 நிமிடம் குறைந்தபட்சம்.",
  "bp.m_txa_push": "TXA {dose} IV/ IO 10 நிமிடங்களுக்கு மேல் - DEADLINE {deadline}. 8 மணி நேரத்திற்கு மேல் அதே டோஸுடன் பின்பற்றவும்.",
  "bp.m_controlled": "இரத்தப்போக்கு கட்டுப்படுத்தப்பட்ட - கண்காணிக்க ஆடை, மறு மதிப்பீடு q5 நிமிடம்.",
  "bp.m_txa_controlled": "TXA 1g IV/IO 10 நிமிடங்களுக்கு மேல் (காயம் {time}, காலக்கெடு {deadline}).",
  "bp.m_no_hemorrhage": "செயலில் இரத்தப்போக்கு இல்லை. மறைமுக உள் இரத்தப்போக்குகளை கண்காணிக்கவும் (தொழில்முறை + VS போக்கு).",
  "bp.a_obstructed": "OBSTRUCTED - வாயில் தள்ளுதல் / கன்னம் உடனடியாக உயர்த்தல். NPA இல்லை என்றால் சந்தேகத்திற்குரிய அடிப்பகுதி தலையின் முறிவு.",
  "bp.a_cric": "NPA தோல்வியுற்றால்: அறுவை சிகிச்சை மூலம் சுவாச வழி (கிரிகோதிரோட்டமி).",
  "bp.a_npa": "NPA செருகல்ஃ மெருகூட்டல், வலது மூக்கு துளை செருகல். முதுகெலும்பு கவலை இல்லாமல் நனவில்லாமல் இருந்தால் மீட்பு நிலையை கருத்தில் கொள்ளவும்.",
  "bp.a_patent": "காற்று வழி காப்புரிமை. நிலையை பராமரிக்கவும், LOC மாற்றம் இருந்தால் மறு மதிப்பீடு செய்யவும்.",
  "bp.a_gcs_low": "GCS <= 8 -- அதிக சுவாச ஆபத்து. சுவாச வழிகளைப் பாதுகாக்கவும். வளங்கள் அனுமதித்தால் மேம்பட்ட சுவாச வழிகளை கருத்தில் கொள்ளவும்.",
  "bp.r_absent": "மூச்சு ஒலிகள் இல்லை - சுவாச வழிகளை உறுதிப்படுத்தவும், BVM காற்றோட்டம் தொடங்கவும்.",
  "bp.r_tension": "மன அழுத்தம் நுனோமோ சந்தேகம் - ஊசி decompression NOW: 2 வது ஐசிஎஸ் midclavicular line, 14g ஊசி. காற்று வேகம் = உறுதிப்படுத்தல்.",
  "bp.r_tension_repeat": "எந்த முன்னேற்றமும் இல்லாவிட்டால்ஃ எதிர் பக்கத்தை சரிபார்க்கவும். காற்று ஓடுவதை நிறுத்தினால் மீண்டும் செய்யவும்.",
  "bp.r_open_chest": "திறந்த மார்பக காயம் - காற்றோட்டம் காற்றோட்டம் முத்திரை விரும்பப்படுகிறது. மூன்று பக்க முத்திரை காற்றோட்டம் கிடைக்கவில்லை என்றால்.",
  "bp.r_open_chest_monitor": "முத்திரையிடப்பட்ட பிறகு பதற்றம் கண்காணிக்க - முத்திரை பர்ப் அல்லது காற்றோட்டம் மாற்ற வேண்டும்.",
  "bp.r_diminished": "மூச்சு வீழ்ச்சி ஒரு பக்கத்தில் ஒலிக்கிறது - ஹெமோதொராக்ஸ் / நியூமோதொராக்ஸ் வளர்ச்சிக்கு மறுபரிசீலனை.",
  "bp.r_effective": "சுவாச செயல்திறன். SpO2 {spo2}%. கிடைக்கும் போது கூடுதல் O2 மற்றும் SpO2 < 94%.",
  "bp.c_severe": "பெரிய துளை IV x2 அல்லது IO. LR 1L - SBP 80-90 mmHg (தீர்க்கக்கூடிய ஹைபோடென்ஷன்) க்கு டைட்ரேட் செய்யவும். SBP > 90 ஊடுருவும் தொடையில் இருந்தால் திரவங்களை நிறுத்துங்கள்.",
  "bp.c_shock_index": "அதிர்ச்சி குறியீடு: {si} {sev}",
  "bp.c_moderate": "IV அணுகல் (18 கிராம் நிமிடம்). LR 500mL பொல்ஸ், மறு மதிப்பீடு. முன்னேற்றத்திற்கான கண்காணிப்பு.",
  "bp.c_stable": "சிகிச்சை திரவங்கள், வி. எஸ் மோசமடையாவிட்டால்.",
  "bp.h_active": "செயலில் உள்ள குறைவான வெப்பநிலை - உடனடியாக ஈரமான ஆடைகளை அகற்றவும். தனிமைப்படுத்தவும். வெப்ப IV திரவங்கள். வெப்பப் பொதிகள் அச்சுகள் / கழுகுகள் (சரியாக சருமத்தில் இல்லை).",
  "bp.h_gentle": "மென்மையாக கையாளுதல் - மிதமான / கடுமையான ஹைபோதர்மி VFib ஆபத்து ஏற்படுகிறது.",
  "bp.h_prevent": "குறைவான வெப்பநிலையைத் தடுக்கவும்ஃ ஈரமான ஆடைகள், இடைவெளி துணிகள், தரையில் இருந்து தனிமைப்படுத்தல் ஆகியவற்றை அகற்றவும். சிகிச்சையின் போது உலர வைக்கவும்.",
  "bp.u_cefazolin": "செஃபாசோலின் {dose} IV q8h - அறுவை சிகிச்சை தடுப்பு. அறுவை சிகிச்சைக்கு 60 நிமிடங்களுக்குள் கொடுக்கவும்.",
  "bp.u_amoxicillin": "அமோக்ஸிக்சிலின் {dose} PO q8h x7 நாட்கள் - காயம் தடுப்பு.",
  "bp.u_amox_pregnant": "அமோக்ஸிக்சிலின் 500mg PO q8h x7 நாட்கள் - பெனிசிலின் அலர்ஜி, ஆனால் கர்ப்ப காலத்தில் தேவைப்படுகிறது (டோக்ஸிக்சிலின் contraindicated).",
  "bp.u_doxycycline": "Doxycycline 100mg PO q12h x7 நாட்கள் - பெனிசிலின் அலர்ஜி மாற்றம்.",
  "bp.u_ketamine": "கெட்டமைன் {kIV}mg IV மெதுவாக ஊக்குவிக்கவும் (0.2mg/kg) OR {kIM}mg IM. Q30min ஐ மறுபரிசீலனை செய்யவும்.",
  "bp.u_ondansetron": "Ondansetron {dose} IV/ODT PRN வலி (குறிப்பாக கெட்டமினுடன்).",
  "bp.u_spinal": "சந்தேகப்பட்ட முதுகெலும்பு -- இன்லைன் நிலைத்தன்மையை பராமரிக்கவும். 3+ நபர்கள் குழுவுடன் பதிவு செய்யவும். அனைத்து இயக்கங்களையும் குறைக்கவும்.",
  "bp.u_lateral": "இடது பக்க விறைப்பு அல்லது இடது இடுப்பு விளிம்பு - aortocaval சுருக்கத்தை குறைக்கிறது.",
  "bp.u_oxytocin": "ஆக்ஸிடோசின் 10U உடனடியாக பிளாசண்டல் பிரசவத்திற்குப் பிறகு. PPH க்கு 1L IV இல் 10-40U உடன் பின்பற்றவும்.",
  "bp.drug_txa_name": "TXA (ட்ரான்செமிக் அமிலம்)",
  "bp.drug_txa_timing_deadline": "இப்போது - காலக்கெடு {deadline}",
  "bp.drug_txa_timing_now": "இப்போது",
  "bp.drug_txa_regimen": "{dose} 10 நிமிடங்களுக்கு மேல், பின்னர் அதே டோஸ் 8 மணி நேரத்திற்கு மேல்",
  "bp.drug_txa_warning": "காயத்திலிருந்து 3 மணி நேர விண்டோ. {deadline} - கொடுக்க வேண்டாம் (மரணத்தை அதிகரிக்கிறது).",
  "bp.drug_ketamine_name": "கெட்டமைன்",
  "bp.drug_ketamine_timing": "PRN வலி, q30-60 min அதிகபட்சம்",
  "bp.drug_ketamine_regimen": "{dose} IV மெதுவான தூண்டுதல் PRN. மறு மதிப்பீட்டிற்கு முன் அதிகபட்சம் 3 டோஸ்.",
  "bp.drug_ketamine_warning": "ஏற்படக்கூடிய எதிர்வினைகள். நீண்ட கால பயன்பாட்டிற்கு முன்னர் midazolam 1mg IV உடன் மருந்து எடுத்துக் கொள்ளவும்.",
  "bp.drug_ondansetron_name": "ஒண்டான்செட்ரோன்",
  "bp.drug_ondansetron_timing": "PRN வலி",
  "bp.drug_ondansetron_regimen": "{dose} IV q6h PRN.",
  "bp.mon_vitals": "ஒவ்வொரு {freq} நிமிடத்திற்கும் (HR, SBP, RR, SpO2) அத்தியாவசியங்கள்.",
  "bp.mon_gcs": "GCS: ஒவ்வொரு 15 நிமிடங்களுக்கும் மறுபரிசீலனை செய்யுங்கள்.",
  "bp.mon_dressings": "ஆடைகள்ஃ ஹீமோஸ்டாசிஸ் உறுதிப்படுத்தப்படும் வரை q5 min ஐ மறுபரிசீலனை செய்யவும்.",
  "bp.mon_internal": "உள் இரத்தப்போக்கு அறிகுறிகளை கண்காணிக்கவும் (HR போக்கு, SBP போக்கு).",
  "bp.mon_urine": "சிறுநீர் வெளியீடுஃ இலக்கு > 0.5 mL/kg/h (தகுந்த ஊசி).",
  "bp.mon_temp": "வெப்பநிலைஃ q30 நிமிடம் மறுபரிசீலனை செய்யுங்கள், வெப்ப இழப்பைத் தடுக்கவும்.",
  "bp.mon_txa": "TXA பராமரிப்பு ஊசிஃ {deadline} வரை 8 மணி நேரம் முழுமையான பை.",
  "bp.mon_decomp": "பிந்தைய அழுத்தம்ஃ சுவாச ஒலிகளை 15 நிமிடத்திற்குள் மறுபரிசீலனை செய்யவும்.",
  "bp.rx_txa": "({n}) TXA {dose} IV 10 நிமிடங்களுக்கு மேல் - பின்னர் அதே டோஸ் 8 மணி நேரத்திற்கு மேல்",
  "bp.rx_cefazolin": "({n}) செஃபாசோலின் {dose} IV q8h x24hr",
  "bp.rx_amoxicillin": "({n}) Amoxicillin {dose} PO q8h x7 நாட்கள்",
  "bp.rx_doxycycline": "({n}) Doxycycline 100mg PO q12h x7 நாட்கள்",
  "bp.rx_ketamine": "({n}) Ketamine {dose} IV PRN வலி (q30min அதிகபட்சம், 3 டோஸ்களுக்குப் பிறகு மறுபரிசீலனை)",
  "bp.rx_ondansetron": "({n}) Ondansetron {dose} IV/ODT q6h PRN வலி",
  "bp.rx_oxytocin": "({n}) ஆக்ஸிடோசின் 10U IM பிளாசண்டல் பிரசவத்திற்குப் பிறகு - பின்னர் 40U/1L IV ஊசி PRN",
  "bp.rec_dcs": "சேதம் கட்டுப்படுத்தும் அறுவை சிகிச்சை தேவைப்படலாம். MEDEVAC உடனடியாக அறுவை சிகிச்சை வசதிக்கு.",
  "bp.rec_triad": "கொடூர முக்கோண அபாயம் (ஹைபோதர்மி + கொய்குலோபதி + அசிடோசிஸ்) - முழுமையான ஆக்கிரமிப்பு தடுப்பு.",
  "bp.rec_los_long": "எதிர்பார்த்த மருத்துவமனை LOS: 7-21 நாட்கள் ஆபரேஷன் போக்கைப் பொறுத்து.",
  "bp.rec_significant": "ஹெமோடைனமிக் ரீதியாக குறிப்பிடத்தக்க இரத்த இழப்பு. கட்டிடத்தில் தொடர் கண்காணிப்பு. எதிர்பார்க்கப்பட்ட LOS: 3-7 நாட்கள்.",
  "bp.rec_stable": "மதிப்பீட்டின் போது ஹெமோடைனமிக் ரீதியாக நிலையானது. காயம் பராமரிப்பு, நுண்ணுயிர் எதிர்ப்பிகள், வலி கட்டுப்பாடு. தினமும் மறு மதிப்பீடு செய்யவும்.",
  "bp.rec_tbi": "TBI: {gcsCat} -- நரம்பியல் சோதனை q1-2h. CT தலை வரும்போது. இரண்டாம் நிலை காயம் தவிர்க்கவும் (SBP > 90, SpO2 > 94%).",
  "bp.rec_chest": "மார்பக காயம் - சிஎக்ஸ்ஆர் வருகை. ஹெமோடோராக்ஸ் வளர்ச்சி கண்காணிப்பு. மார்பக குழாய் வாசல் குறைவாக உள்ளது.",
  "bp.rec_obstetric": "கருத்தரிப்புஃ கருவின் வருகை கண்காணிப்பு. தாயின் நிலைப்படுத்தல் = கருவின் நிலைப்படுத்தல். OBGYN அறிவிப்பு.",
  "bp.esc_sbp": "கட்டுப்படுத்தப்பட்ட இரத்தப்போக்கு மற்றும் திரவங்கள் இருந்தபோதிலும் SBP 80 mmHg க்கும் குறைவாக குறைகிறது.",
  "bp.esc_gcs": "GCS ஆரம்ப மதிப்பீட்டிலிருந்து > 2 புள்ளிகள் குறைகிறது.",
  "bp.esc_spo2": "SpO2 கூடுதல் O2 மீது 90% க்கும் குறைவாக குறைகிறது.",
  "bp.esc_hr": "HR > 140 அல்லது புதிய bradycardia < 50.",
  "bp.esc_tq": "Tourniquet தளத்தில் புதுப்பிக்கப்பட்ட/ மோசமான இரத்தப்போக்கு காணப்படுகிறது.",
  "bp.esc_rr": "சுவாச வீதம் > 30 அல்லது < 8.",
  "bp.esc_decomp": "பிந்தைய அடர்த்திஃ தொடர்ச்சியான சுவாச நோய் - மீண்டும் ஊசி அல்லது மார்பக குழாய்.",
  "bp.esc_breath": "புதிய ஒற்றை பக்க இல்லாத சுவாச ஒலிகள்.",
  "bp.esc_txa": "TXA {deadline} க்கு முன்னர் வழங்கப்படவில்லை - ஆவணம், விண்டோவுக்குப் பிறகு கொடுக்க வேண்டாம்.",
