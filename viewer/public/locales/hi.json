  "bp.m_tourniquet": "टर्नीकेट लगाएं - ऊंचा और कस, घाव के करीब 2-3 में। टर्नीकेट पर समय लिखें।",
  "bp.m_pack_wound": "पैक घावः हेमोस्टैटिक गाज़ (कम्बैट गाज़), प्रत्यक्ष दबाव न्यूनतम 3 मिनट।",
  "bp.m_txa_push": "TXA {dose} IV/IO 10 मिनट से अधिक - DEADLINE {deadline}. 8 घंटे से अधिक समय तक उसी खुराक के साथ पालन करें।",
  "bp.m_controlled": "रक्तस्राव नियंत्रित - कपड़े की निगरानी, Q5 मिनट का पुनर्मूल्यांकन।",
  "bp.m_txa_controlled": "TXA 1g IV/IO 10 मिनट से अधिक (क्षति {time}, समय सीमा {deadline}) ।",
  "bp.m_no_hemorrhage": "कोई सक्रिय रक्तस्राव नहीं। छिपे हुए आंतरिक रक्तस्राव (यंत्र + वीएस प्रवृत्ति) की निगरानी करें।",
  "bp.a_obstructed": "संदिग्ध नाक खोपड़ी के फ्रैक्चर के मामले में एनपीए।",
  "bp.a_cric": "यदि एनपीए विफल हो जाता हैः सर्जिकल वायुमार्ग (क्रिकोथिरोटमी) ।",
  "bp.a_npa": "एनपीए सम्मिलनः स्नेहक, दाहिने नाक छिद्र सम्मिलित करें। यदि वे अस्वस्थ हैं तो रीढ़ की हड्डी की चिंता के बिना पुनर्प्राप्ति स्थिति पर विचार करें।",
  "bp.a_patent": "वायुमार्ग पेटेंट, स्थिति बनाए रखें, यदि LOC बदलता है तो फिर से मूल्यांकन करें।",
  "bp.a_gcs_low": "जीसीएस <= 8-- उच्च aspiration जोखिम। वायुमार्ग की रक्षा। उन्नत वायुमार्ग पर विचार करें यदि संसाधन अनुमति देते हैं।",
  "bp.r_absent": "कोई सांस की आवाज नहीं - श्वसन पथ की पुष्टि करें, बीवीएम वेंटिलेशन शुरू करें।",
  "bp.r_tension": "तनाव निमोमो संदिग्ध - सुई decompression NOW: 2nd आईसीएस midclavicular लाइन, 14g सुई. हवा की गति = पुष्टि.",
  "bp.r_tension_repeat": "यदि कोई सुधार नहींः विपरीत पक्ष की जांच करें। यदि हवा दौड़ना बंद कर देती है तो दोहराएं।",
  "bp.r_open_chest": "खुले छाती के घाव - वेंटिलेटेड छाती सील पसंद किया. तीन पक्षीय सील यदि वेंटिलेटेड अनुपलब्ध है.",
  "bp.r_open_chest_monitor": "सील के बाद तनाव के लिए मॉनिटर - सील बुलबुला करने या हवा में परिवर्तित करने की आवश्यकता हो सकती है।",
  "bp.r_diminished": "एक तरफ श्वास में कमी की आवाज़ें - हेमोथोरैक्स/न्यूमोथोरैक्स के विकास के लिए पुनर्मूल्यांकन। SpO2 {spo2}%",
  "bp.r_effective": "सांस लेने में प्रभावी। SpO2 {spo2}%। उपलब्ध होने पर अतिरिक्त O2 और SpO2 < 94%।",
  "bp.c_severe": "बड़े-बोरे IV x2 या IO. LR 1L -- SBP 80-90 mmHg (अनुमति हाइपोटेंशन) तक टायटरेट करें। यदि SBP > 90 में प्रवेश करने वाले टर्सो में तरल पदार्थों को रोकें।",
  "bp.c_shock_index": "झटका सूचकांक: {si} {sev}",
  "bp.c_moderate": "IV पहुंच (18 ग्राम मिनट) LR 500mL बोलस, पुनर्मूल्यांकन प्रगति की निगरानी।",
  "bp.c_stable": "दवाओं के लिए इंजेक्शन इंजेक्शन तक पहुंच।",
  "bp.h_active": "सक्रिय हाइपोथर्मिया - तुरंत गीले कपड़े निकालें. अछूता. गर्म IV तरल पदार्थ. गर्मी पैक axillae / groin (सीधे त्वचा पर नहीं) ।",
  "bp.h_gentle": "सौम्य रूप से संभालें-- मध्यम/गंभीर हाइपोथर्मिया में विफाइब के जोखिम होते हैं।",
  "bp.h_prevent": "हाइपोथर्मिया को रोकेंः गीले कपड़े, अंतरिक्ष कंबल को हटा दें, जमीन से अछूता रखें। उपचार के दौरान सूखा रखें।",
  "bp.u_cefazolin": "सीफ़ाज़ोलिन {dose} IV q8h - सर्जिकल प्रोफाइलैक्सिस। काटने के 60 मिनट के भीतर दें।",
  "bp.u_amoxicillin": "अमोक्सिसिलिन {dose} पीओ q8h x7 दिन - घाव निवारण।",
  "bp.u_amox_pregnant": "अमोक्सिसिलिन 500mg PO q8h x7 दिन - पेनिसिलिन एलर्जी, लेकिन गर्भावस्था में आवश्यक (डॉक्सीसाइक्लिन contraindicated) ।",
  "bp.u_doxycycline": "Doxycycline 100mg PO q12h x7 दिन - पेनिसिलिन एलर्जी प्रतिस्थापन।",
  "bp.u_ketamine": "केटामिन {kIV}mg IV धीमी धक्का (0.2mg/kg) OR {kIM}mg IM. Q30min का पुनर्मूल्यांकन करें।",
  "bp.u_ondansetron": "Ondansetron {dose} IV/ODT PRN जलन (विशेष रूप से केटामिन के साथ) ।",
  "bp.u_spinal": "संदिग्ध रीढ़ की हड्डी -- इनलाइन स्थिरता बनाए रखें. 3+ व्यक्ति टीम के साथ लॉग रोल करें. सभी आंदोलनों को कम से कम करें.",
  "bp.u_lateral": "बाएं साइडल डिक्युबिटस या बाएं कूल्हे की क्विज-- एओर्टोकैवल संपीड़न को कम करता है।",
  "bp.u_oxytocin": "प्लेसेंटल डिलीवरी के बाद ऑक्सीटोसिन 10U IM के साथ पीपीएच के लिए 1L IV में 10-40U के साथ पालन करें।",
  "bp.drug_txa_name": "TXA (ट्रेनेक्सामिक एसिड)",
