  "bp.m_tourniquet": "Apply tourniquet -- high and tight, 2-3 in proximal to wound. Write time on tourniquet.",
  "bp.m_pack_wound": "Pack wound: hemostatic gauze (Combat Gauze), direct pressure 3 min minimum.",
  "bp.m_txa_push": "TXA {dose} IV/IO over 10 min -- DEADLINE {deadline}. Follow with same dose over 8hr.",
  "bp.m_controlled": "Hemorrhage controlled -- monitor dressing, reassess q5 min.",
  "bp.m_txa_controlled": "TXA 1g IV/IO over 10 min (injury {time}, deadline {deadline}).",
  "bp.m_no_hemorrhage": "No active hemorrhage. Monitor for occult internal bleeding (mechanism + VS trend).",
  "bp.a_obstructed": "OBSTRUCTED -- jaw thrust / chin lift immediately. NPA if not suspected basilar skull fracture.",
  "bp.a_cric": "If NPA fails: surgical airway (cricothyrotomy).",
  "bp.a_npa": "NPA insertion: lubricate, insert right nostril. Consider recovery position if unconscious without spinal concern.",
  "bp.a_patent": "Airway patent. Maintain position, reassess if LOC changes.",
  "bp.a_gcs_low": "GCS <= 8 -- high aspiration risk. Protect airway. Consider advanced airway if resources allow.",
  "bp.r_absent": "No breath sounds -- confirm airway, initiate BVM ventilation.",
  "bp.r_tension": "Tension pneumo suspected -- needle decompression NOW: 2nd ICS midclavicular line, 14g needle. Rush of air = confirmation.",
  "bp.r_tension_repeat": "If no improvement: check opposite side. Repeat if air stops rushing.",
  "bp.r_open_chest": "Open chest wound -- vented chest seal preferred. Three-side seal if vented unavailable.",
  "bp.r_open_chest_monitor": "Monitor for tension after sealing -- may need to burp seal or convert to vented.",
  "bp.r_diminished": "Diminished breath sounds one side -- reassess for developing hemothorax/pneumothorax. SpO2 {spo2}%.",
  "bp.r_effective": "Breathing effective. SpO2 {spo2}%. Supplemental O2 if available and SpO2 < 94%.",
  "bp.c_severe": "Large-bore IV x2 or IO. LR 1L -- titrate to SBP 80-90 mmHg (permissive hypotension). STOP fluids if SBP > 90 in penetrating torso.",
  "bp.c_shock_index": "Shock Index: {si} {sev}",
  "bp.c_moderate": "IV access (18g min). LR 500mL bolus, reassess. Monitor for progression.",
  "bp.c_stable": "IV access for medication administration. Maintenance fluids unless VS worsen.",
  "bp.h_active": "Active hypothermia -- remove wet clothing immediately. Insulate. Warm IV fluids. Heat packs axillae/groin (not directly on skin).",
  "bp.h_gentle": "Handle GENTLY -- moderate/severe hypothermia carries VFib risk from jarring.",
  "bp.h_prevent": "Prevent hypothermia: remove wet clothing, space blanket, insulate from ground. Keep dry throughout treatment.",
  "bp.u_cefazolin": "Cefazolin {dose} IV q8h -- surgical prophylaxis. Give within 60 min of incision.",
  "bp.u_amoxicillin": "Amoxicillin {dose} PO q8h x7 days -- wound prophylaxis.",
  "bp.u_amox_pregnant": "Amoxicillin 500mg PO q8h x7 days -- penicillin allergy, but required in pregnancy (doxycycline contraindicated).",
  "bp.u_doxycycline": "Doxycycline 100mg PO q12h x7 days -- penicillin allergy substitution.",
  "bp.u_ketamine": "Ketamine {kIV}mg IV slow push (0.2mg/kg) OR {kIM}mg IM. Reassess q30min. Have midazolam 1-2mg IV for emergence.",
  "bp.u_ondansetron": "Ondansetron {dose} IV/ODT PRN nausea (especially with ketamine).",
  "bp.u_spinal": "Suspected spinal -- maintain inline stabilization. Log roll with 3+ person team. Minimize all movement.",
  "bp.u_lateral": "Left lateral decubitus or left-hip wedge -- reduces aortocaval compression.",
  "bp.u_oxytocin": "Oxytocin 10U IM AFTER placental delivery. Follow with 10-40U in 1L IV for PPH.",
