{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HALT",
  "version": "1.1.0",
  "identifier": "HermeticLabs.HALT-HermeticAnonymousLocalTriage",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:7777",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "HALT",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Hermetic Labs LLC",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
