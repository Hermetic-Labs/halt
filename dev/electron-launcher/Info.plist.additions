<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    EVE OS macOS Info.plist Additions
    Privacy descriptions and app metadata for macOS
    Merge these entries into the generated Info.plist
-->
<plist version="1.0">
<dict>
    <!-- App Identity -->
    <key>CFBundleName</key>
    <string>EVE OS</string>
    
    <key>CFBundleDisplayName</key>
    <string>EVE OS</string>
    
    <key>CFBundleIdentifier</key>
    <string>com.hermeticlabs.eveos</string>
    
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    
    <!-- Publisher Info -->
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2025 Hermetic Labs. All rights reserved.</string>
    
    <!-- App Category -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.medical</string>
    
    <!-- Minimum OS -->
    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>
    
    <!-- High Resolution -->
    <key>NSHighResolutionCapable</key>
    <true/>
    
    <!-- Privacy Descriptions (Required for App Store) -->
    
    <!-- Camera - if using webcam for biometrics -->
    <key>NSCameraUsageDescription</key>
    <string>EVE OS uses the camera for optional biometric authentication and telemedicine features. Camera access is never required and data is processed locally.</string>
    
    <!-- Microphone - if using voice input -->
    <key>NSMicrophoneUsageDescription</key>
    <string>EVE OS uses the microphone for optional voice commands and dictation features. Audio is processed locally and not transmitted.</string>
    
    <!-- Health Data - if accessing HealthKit -->
    <key>NSHealthShareUsageDescription</key>
    <string>EVE OS can read health data from Apple Health to display your vitals and health metrics. This data stays on your device.</string>
    
    <key>NSHealthUpdateUsageDescription</key>
    <string>EVE OS can save health-related information to Apple Health for your records.</string>
    
    <!-- Location - if used -->
    <key>NSLocationUsageDescription</key>
    <string>EVE OS may use location for emergency services routing and regional compliance features.</string>
    
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>EVE OS uses location only when the app is open for emergency services and regional settings.</string>
    
    <!-- Contacts - if syncing patients -->
    <key>NSContactsUsageDescription</key>
    <string>EVE OS can access contacts to help you associate patient records with contact information.</string>
    
    <!-- Calendars - if scheduling -->
    <key>NSCalendarsUsageDescription</key>
    <string>EVE OS can access your calendar to schedule appointments and reminders.</string>
    
    <!-- Local Network - for local API access -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>EVE OS uses the local network to communicate with the EVE backend services running on your machine.</string>
    
    <key>NSBonjourServices</key>
    <array>
        <string>_http._tcp</string>
        <string>_https._tcp</string>
    </array>
    
    <!-- Apple Events - for Docker control -->
    <key>NSAppleEventsUsageDescription</key>
    <string>EVE OS uses Apple Events to manage Docker Desktop and other automation tasks.</string>
    
    <!-- App Transport Security - Allow localhost -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsLocalNetworking</key>
        <true/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
            <key>127.0.0.1</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
            </dict>
        </dict>
    </dict>
    
    <!-- Export Compliance -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    
    <!-- Document Types (if handling medical files) -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>EVE OS Document</string>
            <key>CFBundleTypeExtensions</key>
            <array>
                <string>eveos</string>
            </array>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
        </dict>
    </array>
    
    <!-- URL Schemes -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.hermeticlabs.eveos</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>eveos</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
