{
  "id": "pediatric-vital-sign-ranges",
  "name": "小児の正常なバイタルサイン範囲",
  "description": "HR、RR、SBPの年齢調整済み基準。小児患者の正しいトリアージ分類には重要です。成人の正常範囲は子供にとっては不正確です。",
  "ranges": [
    {
      "age": "新生児 (0 ～ 1 か月)",
      "hr": "100-160",
      "rr": "30-60",
      "sbp_mmhg": "60-90",
      "gcs_min": 15
    },
    {
      "age": "幼児 (1 ～ 12 か月)",
      "hr": "90-150",
      "rr": "30-60",
      "sbp_mmhg": "70-100",
      "gcs_min": 15
    },
    {
      "age": "幼児 (1 ～ 3 歳)",
      "hr": "80-130",
      "rr": "24-40",
      "sbp_mmhg": "80-110",
      "gcs_min": 15
    },
    {
      "age": "子供 (3 ～ 12 歳)",
      "hr": "70-120",
      "rr": "18-30",
      "sbp_mmhg": "80-120",
      "gcs_min": 15
    },
    {
      "age": "青年期 (12 歳以上)",
      "hr": "60-100",
      "rr": "12-20",
      "sbp_mmhg": "90-130",
      "gcs_min": 15
    }
  ],
  "source": "PALS Guidelines / JTS Pediatric CPG"
}
