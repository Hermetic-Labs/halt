{
  "id": "pediatric-vital-sign-ranges",
  "name": "Normale Vitalzeichenbereiche bei Kindern",
  "description": "Altersbereinigte Referenz für HR, RR und SBP. Entscheidend für die korrekte Triage-Klassifizierung bei pädiatrischen Patienten – die Normalbereiche für Erwachsene sind für Kinder falsch.",
  "ranges": [
    {
      "age": "Neugeborenes (0-1 Monat)",
      "hr": "100-160",
      "rr": "30-60",
      "sbp_mmhg": "60-90",
      "gcs_min": 15
    },
    {
      "age": "Kleinkind (1–12 Monate)",
      "hr": "90-150",
      "rr": "30-60",
      "sbp_mmhg": "70-100",
      "gcs_min": 15
    },
    {
      "age": "Kleinkind (1-3 Jahre)",
      "hr": "80-130",
      "rr": "24-40",
      "sbp_mmhg": "80-110",
      "gcs_min": 15
    },
    {
      "age": "Kind (3-12 Jahre)",
      "hr": "70-120",
      "rr": "18-30",
      "sbp_mmhg": "80-120",
      "gcs_min": 15
    },
    {
      "age": "Jugendlicher (>12 Jahre)",
      "hr": "60-100",
      "rr": "12-20",
      "sbp_mmhg": "90-130",
      "gcs_min": 15
    }
  ],
  "source": "PALS Guidelines / JTS Pediatric CPG"
}
