{
  "id": "pediatric-vital-sign-ranges",
  "name": "儿科正常生命体征范围",
  "description": "HR、RR 和 SBP 的年龄调整参考。对于儿科患者的正确分诊分类至关重要——成人正常范围对于儿童来说是不正确的。",
  "ranges": [
    {
      "age": "新生儿（0-1 个月）",
      "hr": "100-160",
      "rr": "30-60",
      "sbp_mmhg": "60-90",
      "gcs_min": 15
    },
    {
      "age": "婴儿（1-12 个月）",
      "hr": "90-150",
      "rr": "30-60",
      "sbp_mmhg": "70-100",
      "gcs_min": 15
    },
    {
      "age": "幼儿（1-3 岁）",
      "hr": "80-130",
      "rr": "24-40",
      "sbp_mmhg": "80-110",
      "gcs_min": 15
    },
    {
      "age": "儿童（3-12岁）",
      "hr": "70-120",
      "rr": "18-30",
      "sbp_mmhg": "80-120",
      "gcs_min": 15
    },
    {
      "age": "青少年（>12 岁）",
      "hr": "60-100",
      "rr": "12-20",
      "sbp_mmhg": "90-130",
      "gcs_min": 15
    }
  ],
  "source": "PALS Guidelines / JTS Pediatric CPG"
}