      "sbp_mmhg": "80-110",
      "gcs_min": 15
    },
    {
      "age": "Kind (3-12 jaar)",
      "hr": "70-120",
      "rr": "18-30",
      "sbp_mmhg": "80-120",
      "gcs_min": 15
    },
    {
      "age": "Adolescent (>12 jaar)",
      "hr": "60-100",
