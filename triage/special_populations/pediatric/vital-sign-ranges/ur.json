{
  "id": "pediatric-vital-sign-ranges",
  "name": "پیڈیاٹرک نارمل وائٹل سائن رینجز",
  "description": "HR، RR، اور SBP کے لیے عمر کے لحاظ سے ایڈجسٹ شدہ حوالہ۔ بچوں کے مریضوں میں درست ٹرائیج کی درجہ بندی کے لیے اہم -- بالغوں کی نارمل رینجز بچوں کے لیے غلط ہیں۔",
  "ranges": [
    {
      "age": "نوزائیدہ (0-1 ماہ)",
      "hr": "100-160",
      "rr": "30-60",
      "sbp_mmhg": "60-90",
      "gcs_min": 15
    },
    {
      "age": "شیرخوار (1-12 ماہ)",
      "hr": "90-150",
      "rr": "30-60",
      "sbp_mmhg": "70-100",
      "gcs_min": 15
    },
    {
      "age": "چھوٹا بچہ (1-3 سال)",
      "hr": "80-130",
      "rr": "24-40",
      "sbp_mmhg": "80-110",
      "gcs_min": 15
    },
    {
      "age": "بچہ (3-12 سال)",
      "hr": "70-120",
      "rr": "18-30",
      "sbp_mmhg": "80-120",
      "gcs_min": 15
    },
    {
      "age": "نوعمر (>12 سال)",
      "hr": "60-100",
      "rr": "12-20",
      "sbp_mmhg": "90-130",
      "gcs_min": 15
    }
  ],
  "source": "PALS Guidelines / JTS Pediatric CPG"
}